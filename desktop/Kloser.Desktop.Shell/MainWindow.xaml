<Window x:Class="Kloser.Desktop.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Kloser.Desktop.Shell.ViewModels"
        Title="Kloser Desktop Capture"
        Width="1600" Height="1080"
        MinWidth="1280" MinHeight="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="14"
        Foreground="{StaticResource PrimaryTextBrush}">
    <!--
        Phase 9 Step 4 вАФ main window.
        Plan ¬І4.1 layout: header, device band, control band, status grid,
        events/errors, smoke checklist.

        IMPORTANT: the data context is constructed in code-behind so the
        view model can receive a UiDispatcher bound to the live window.
    -->

    <Window.Resources>
        <!--
            ComboBoxмЭШ collapsed мШБмЧ≠(мД†нГЭлРЬ нХ≠л™© нСЬмЛЬ)к≥Љ нОЉм≥РмІД popupмЭШ
            ComboBoxItemмЭА WPF кЄ∞л≥Є нЕЬнФМл¶њмЧРмДЬ лСШ лЛ§ нЭ∞ л∞∞к≤љ мЬДмЧР кЈЄл†§мІДлЛ§.
            мЧђкЄ∞мДЬ Foregroundл•Љ нЭ∞мГЙмЬЉл°Ь лСРл©і кЄАмЮРк∞А лђїнША мХИ л≥імЭілѓАл°Ь
            м†Дм≤і ComboBox к≥ДмЧімЭА л∞ЭмЭА surface + к≤Ам†Х кЄАмЮРл°Ь нЖµмЭЉнХЬлЛ§.
            (лЛ§л•Є мШБмЧ≠мЭШ dark UI мГЙмЭА кЈЄлМАл°Ь мЬ†мІА.)
        -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#334155" />
                    <Setter Property="Foreground" Value="#94A3B8" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,0,0,0" />
        </Style>
        <Style TargetType="ProgressBar" x:Key="LevelBar">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ProgressBar" x:Key="RmsBar" BasedOn="{StaticResource LevelBar}">
            <Setter Property="Foreground" Value="#22C55E" />
            <Setter Property="Height" Value="8" />
        </Style>
    </Window.Resources>

    <!--
        Window мЮРм≤іл•Љ ScrollViewerл°Ь к∞РмЛЉлЛ§. Step 5мЧРмДЬ backend + call bandк∞А
        мґФк∞АлРШк≥† status panelмЭі 3-colл°Ь мї§м†ЄмДЬ мЮСмЭА л™®лЛИнД∞мЧРмД† нХШлЛ®(smoke
        checklist + transcript) мЭі мЮШл†§ л≥імШАлЛ§. VerticalScrollBarVisibility=Auto
        л°Ь лСРл©і л™®лЛИнД∞ нБђл©і мК§нБђл°§ мХИ л≥імЭік≥†, мЮСмЬЉл©і мЮРлПЩмЬЉл°Ь мГЭкЄілЛ§.
    -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0 header -->
            <RowDefinition Height="Auto"/> <!-- 1 device band -->
            <RowDefinition Height="Auto"/> <!-- 2 Phase 9 Step 5 backend + call band -->
            <RowDefinition Height="Auto"/> <!-- 3 capture control band -->
            <RowDefinition Height="Auto"/> <!-- 4 status + events + transcripts (Auto: ScrollViewer мХИмЧРмД† л≥Дл°Ь мХИ лКШмЦілВ®) -->
            <RowDefinition Height="Auto"/> <!-- 5 smoke checklist -->
        </Grid.RowDefinitions>

        <!-- ================ Header ================ -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding AppVersion}" Style="{StaticResource HeaderText}" FontSize="22"/>
                    <TextBlock Text="Phase 9 Step 5 вАФ лН∞мК§нБђнГС мЇ°м≤ШмЧРмДЬ backend mock STTкєМмІА мЛ§мЛЬк∞Д мЧ∞к≤∞нХ©лЛИлЛ§." Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="мГБнГЬ:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding UiStateLabel}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="к≤љк≥Љ:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ElapsedDisplay}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="л©Фл™®л¶ђ:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource ValueText}">
                        <Run Text="{Binding MemoryMb, StringFormat={}{0:F1}}"/><Run Text=" MB"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================ Device Band ================ -->
        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,8">
                    <TextBlock Text="лІИмЭінБђ (мЇ°м≤Ш мЮ•мєШ)" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding CaptureDevices}"
                              SelectedItem="{Binding SelectedMic, Mode=TwoWay}"
                              DisplayMemberPath="Display"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,8">
                    <TextBlock Text="мЛЬмК§нЕЬ мШ§лФФмШ§ (мґЬл†• мЮ•мєШ ¬Ј л£®нФДл∞±)" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding RenderDevices}"
                              SelectedItem="{Binding SelectedLoopback, Mode=TwoWay}"
                              DisplayMemberPath="Display"/>
                </StackPanel>
                <Button Grid.Row="0" Grid.Column="2" Content="мЮ•мєШ мГИл°Ьк≥†мє®" Command="{Binding RefreshDevicesCommand}" VerticalAlignment="Bottom" Margin="0,0,0,8"/>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal">
                    <TextBlock Text="нФДл†ИмЮД кЄЄмЭі (ms)" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding AllowedFrameMs}"
                              SelectedItem="{Binding SelectedFrameMs, Mode=TwoWay}"
                              Width="80" Margin="0,0,16,0"/>
                    <CheckBox Content="мІДлЛ® WAV м†АмЮ• (мЫРмЭМ нММмЭЉ ¬Ј кЄ∞л≥Є кЇЉмІР)"
                              IsChecked="{Binding WriteDiagnosticWav, Mode=TwoWay}"/>
                    <TextBlock Text=" вЖТ " Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Text="{Binding DiagnosticDir, FallbackValue='(м†АмЮ• нПілНФ мЧЖмЭМ)'}" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================ Phase 9 Step 5 вАФ Backend / Call Band ================ -->
        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="л∞±мЧФлУЬ мЧ∞к≤∞ + нЖµнЩФ (Phase 9 Step 5)" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>

                <!-- Row 1 вАФ backend URL + Connect/Disconnect -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="л∞±мЧФлУЬ URL" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding BackendUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#F8FAFC" Foreground="#0F172A" Padding="6,4" MinHeight="28"
                                 BorderBrush="{StaticResource PanelBorderBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="л°ЬкЈЄмЭЄ + мЧ∞к≤∞" Command="{Binding LoginAndConnectCommand}" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="нЖ†нБ∞мЬЉл°Ь мЧ∞к≤∞" Command="{Binding ConnectWithTokenCommand}" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="мЧ∞к≤∞ лБКкЄ∞" Command="{Binding DisconnectCommand}" VerticalAlignment="Bottom"/>
                </Grid>

                <!-- Row 2 вАФ login email + password + paste token -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="мЭіл©ФмЭЉ (мД†нГЭ: л°ЬкЈЄмЭЄ л∞©мЛЭ)" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding LoginEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#F8FAFC" Foreground="#0F172A" Padding="6,4" MinHeight="28"
                                 BorderBrush="{StaticResource PanelBorderBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="лєДл∞Ал≤ИнШЄ (л©Фл™®л¶ђмЧРлІМ л≥ікіА)" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                        <!--
                            WPF PasswordBoxлКФ bindingмЭі мХИ лРШлѓАл°Ь dev нОЄмЭШмГБ
                            TextBoxл°Ь лСФлЛ§. мЮЕл†• нЫД м¶ЙмЛЬ л©Фл™®л¶ђл°Ь мШЃкЄ∞к≥†
                            ViewModelмЭі LoginPasswordл•Љ лєДмЪілЛ§.
                        -->
                        <TextBox Text="{Binding LoginPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#F8FAFC" Foreground="#0F172A" Padding="6,4" MinHeight="28"
                                 BorderBrush="{StaticResource PanelBorderBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="лШРлКФ access token лґЩмЧђлД£кЄ∞ (dev fallback / KLOSER_DESKTOP_ACCESS_TOKEN)" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PastedToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#F8FAFC" Foreground="#0F172A" Padding="6,4" MinHeight="28"
                                 BorderBrush="{StaticResource PanelBorderBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3 вАФ connection / call status + Start/End call + counters -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="мЖМмЉУ:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ConnectionStateLabel}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="нЖµнЩФ:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CallStateLabel}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="callId:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ActiveCallId, FallbackValue='(мЧЖмЭМ)'}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="нЖµнЩФ мЛЬмЮС" Command="{Binding StartCallCommand}"/>
                    <Button Content="нЖµнЩФ мҐЕл£М" Command="{Binding EndCallCommand}"/>
                    <TextBlock Text="agent_mic chunks/bytes:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="16,0,4,0"/>
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource ValueText}">
                        <Run Text="{Binding AgentMicChunksSent}"/><Run Text=" / "/><Run Text="{Binding AgentMicBytesSent}"/>
                    </TextBlock>
                    <TextBlock Text="system_loopback chunks/bytes:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="16,0,4,0"/>
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource ValueText}">
                        <Run Text="{Binding SystemLoopbackChunksSent}"/><Run Text=" / "/><Run Text="{Binding SystemLoopbackBytesSent}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Row 4 вАФ last realtime error -->
                <TextBlock Text="{Binding LastRealtimeError, FallbackValue=''}"
                           Style="{StaticResource ValueText}"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- ================ Capture Control Band ================ -->
        <Border Grid.Row="3" Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="мЇ°м≤Ш мЛЬмЮС" Command="{Binding StartCaptureCommand}"/>
                <Button Content="мЇ°м≤Ш м†ХмІА" Command="{Binding StopCaptureCommand}"/>
                <TextBlock Text="л∞±мЧФлУЬ:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="20,0,4,0"/>
                <TextBlock Text="{Binding BackendStatus}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="нЖµнЩФ:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding CallStatus}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="мВђмЪ©мЮР:" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding UserStatus}" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ================ Status + Events + Transcripts ================ -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- per-source status -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding AgentMicStatus.DisplayLabel}" Style="{StaticResource HeaderText}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="нФЉнБђ" Style="{StaticResource LabelText}" VerticalAlignment="Center" Width="40"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource LevelBar}" Value="{Binding AgentMicStatus.PeakPercent, Mode=OneWay}"/>
                            <TextBlock Grid.Column="2" Text="{Binding AgentMicStatus.Peak, StringFormat='F3'}" Style="{StaticResource ValueText}" Width="60" TextAlignment="Right" Margin="6,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="нПЙкЈ†" Style="{StaticResource LabelText}" VerticalAlignment="Center" Width="40"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource RmsBar}" Value="{Binding AgentMicStatus.RmsPercent, Mode=OneWay}"/>
                            <TextBlock Grid.Column="2" Text="{Binding AgentMicStatus.Rms, StringFormat='F3'}" Style="{StaticResource ValueText}" Width="60" TextAlignment="Right" Margin="6,0,0,0"/>
                        </Grid>
                        <UniformGrid Columns="4" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="мВђмЪ© мЧђлґА" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding AgentMicStatus.IsEnabled}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="м†ХмГБ лПЩмЮС" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding AgentMicStatus.IsHealthy}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="нФДл†ИмЮД мИШ" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding AgentMicStatus.FramesEmitted}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="л≤Дл¶∞ нФДл†ИмЮД" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding AgentMicStatus.FramesDropped}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </UniformGrid>
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Text="мЮ•мєШ мЫРл≥Є нШХмЛЭ" Style="{StaticResource LabelText}"/>
                            <TextBlock Text="{Binding AgentMicStatus.NativeFormat}" Style="{StaticResource ValueText}"/>
                            <TextBlock Text="м†ХкЈЬнЩФ нШХмЛЭ" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding AgentMicStatus.NormalizedFormat}" Style="{StaticResource ValueText}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="{Binding SystemLoopbackStatus.DisplayLabel}" Style="{StaticResource HeaderText}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="нФЉнБђ" Style="{StaticResource LabelText}" VerticalAlignment="Center" Width="40"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource LevelBar}" Value="{Binding SystemLoopbackStatus.PeakPercent, Mode=OneWay}"/>
                            <TextBlock Grid.Column="2" Text="{Binding SystemLoopbackStatus.Peak, StringFormat='F3'}" Style="{StaticResource ValueText}" Width="60" TextAlignment="Right" Margin="6,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="нПЙкЈ†" Style="{StaticResource LabelText}" VerticalAlignment="Center" Width="40"/>
                            <ProgressBar Grid.Column="1" Style="{StaticResource RmsBar}" Value="{Binding SystemLoopbackStatus.RmsPercent, Mode=OneWay}"/>
                            <TextBlock Grid.Column="2" Text="{Binding SystemLoopbackStatus.Rms, StringFormat='F3'}" Style="{StaticResource ValueText}" Width="60" TextAlignment="Right" Margin="6,0,0,0"/>
                        </Grid>
                        <UniformGrid Columns="4" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="мВђмЪ© мЧђлґА" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding SystemLoopbackStatus.IsEnabled}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="м†ХмГБ лПЩмЮС" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding SystemLoopbackStatus.IsHealthy}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="нФДл†ИмЮД мИШ" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding SystemLoopbackStatus.FramesEmitted}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="л≤Дл¶∞ нФДл†ИмЮД" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="{Binding SystemLoopbackStatus.FramesDropped}" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </UniformGrid>
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Text="мЮ•мєШ мЫРл≥Є нШХмЛЭ" Style="{StaticResource LabelText}"/>
                            <TextBlock Text="{Binding SystemLoopbackStatus.NativeFormat}" Style="{StaticResource ValueText}"/>
                            <TextBlock Text="м†ХкЈЬнЩФ нШХмЛЭ" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding SystemLoopbackStatus.NormalizedFormat}" Style="{StaticResource ValueText}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- events + errors -->
            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="мШ§л•Ш" Style="{StaticResource HeaderText}" Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Text="мЫРмЭМ лН∞мЭінД∞лВШ мК§нГЭ нКЄл†ИмЭімК§лКФ нСЬмЛЬнХШмІА мХКмКµлЛИлЛ§." Style="{StaticResource LabelText}" TextWrapping="Wrap" Margin="0,2,0,6"/>
                        <ItemsControl ItemsSource="{Binding LastErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="мЭіл≤§нКЄ" Style="{StaticResource HeaderText}"/>
                        <ItemsControl ItemsSource="{Binding Events}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValueText}" TextWrapping="Wrap" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Phase 9 Step 5 вАФ transcript panel -->
            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="мЛ§мЛЬк∞Д мЮРлІЙ (partial)" Style="{StaticResource HeaderText}"/>
                        <TextBlock Text="mock STTмЭШ мЮДмЛЬ мЮРлІЙмЭі sourceл≥Дл°Ь к∞±мЛ†лР©лЛИлЛ§." Style="{StaticResource LabelText}" TextWrapping="Wrap" Margin="0,2,0,6"/>
                        <TextBlock Text="agent_mic" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
