{
  "name": "kloser-server",
  "version": "0.5.0-spike",
  "private": true,
  "type": "module",
  "description": "Kloser backend — Phase 0.5 spike + Phase 1 in progress",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate:up": "node scripts/migrate.mjs up -m migrations -j sql",
    "db:migrate:down": "node scripts/migrate.mjs down -m migrations -j sql",
    "db:migrate:create": "node scripts/migrate.mjs create -m migrations -j sql",
    "db:migrate:redo": "node scripts/migrate.mjs redo -m migrations -j sql",
    "db:seed": "node scripts/run-seed.mjs",
    "test": "tsx --test test/*.test.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.0.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
