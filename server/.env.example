# Server-side env. Copy to server/.env (gitignored).
# Use postgres-host-port from the project-root .env (default 5432).

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
STATIC_ORIGIN=http://localhost:8765

# DB — three URLs by design.
#
#   DATABASE_URL          → runtime (app role, RLS-enforced).
#                           Anything that handles user-facing requests
#                           uses this. The default name is intentional:
#                           libraries that read DATABASE_URL on autopilot
#                           land on the safe role, never the admin one.
#
#   MIGRATE_DATABASE_URL  → migrations + seeds only (admin role, BYPASSRLS).
#                           Required by `npm run db:migrate:*` and
#                           `npm run db:seed`. Wrapper scripts throw if
#                           it is missing.
#
#   SERVICE_DATABASE_URL  → anonymous endpoints only (BYPASSRLS service role).
#                           Used by /auth/verify, /auth/password/reset, and
#                           /invitations/accept — flows whose only server-
#                           side identity is a raw token bearer. Lazy-loaded
#                           at runtime so boot does not require it.
#                           See docs/plan/phase-3/PHASE_3_STEP_2_SIGNUP_VERIFY.md §2.
#
# All three reach the dev container started by ops/docker-compose.yml.
DATABASE_URL=postgres://app:app_dev@localhost:5432/kloser_dev
MIGRATE_DATABASE_URL=postgres://kloser:kloser_dev@localhost:5432/kloser_dev
SERVICE_DATABASE_URL=postgres://kloser_service:kloser_service_dev@localhost:5432/kloser_dev

# Redis — same logic.
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Auth (Step 3)
# ----------------------------------------------------------------------------
# JWT_SECRET — HMAC signing key for access tokens. REQUIRED — server boot
#   fails if missing. Use a long random value in prod (e.g.
#   `openssl rand -base64 48`). The dev value below is fine for local but
#   MUST NOT be reused outside this checkout.
JWT_SECRET=dev-only-change-me-please-this-is-not-a-real-secret-aaaaaaaaaaaa
# Access token TTL. Format accepted by ms()/jsonwebtoken: "15m", "1h", etc.
ACCESS_TOKEN_TTL=15m
# Refresh token (cookie) TTL.
REFRESH_TOKEN_TTL=30d
# Refresh rotation grace window in seconds. Two near-simultaneous refresh
# calls (e.g. multi-tab) within this window are both allowed and the second
# does NOT trigger family revoke. See PHASE_1_STEP_3_AUTH_CORE.md §3.
REFRESH_GRACE_WINDOW_SECONDS=30
# Cookie security. Set COOKIE_SECURE=true behind HTTPS / reverse proxy in
# prod. Dev (plaintext localhost) keeps it false.
COOKIE_SECURE=false

# ----------------------------------------------------------------------------
# Phase 6 Step 1 — workers + demo replay gate
# ----------------------------------------------------------------------------
# KLOSER_DEMO_REPLAY — Phase 0.5 fixture WS replay.
#   "1" / "true"  → on (Phase 0.5/4/5 e2e and dev demos use this)
#   "0" / "false" → off
#   unset         → off in production (NODE_ENV=production), on otherwise
# Keep dev default on so existing e2e suites stay green.
KLOSER_DEMO_REPLAY=1

# Heartbeat sweep — repeatable BullMQ job. Tests override these to keep
# the suite fast. Prod defaults match Phase 5 master plan §2 decision 10/11.
KLOSER_HEARTBEAT_CUTOFF_SEC=60
KLOSER_HEARTBEAT_SWEEP_INTERVAL_SEC=30

# WS suggestion timer — every N milliseconds the live socket asks the
# (mock) LLM for a suggestion group and persists it.
KLOSER_SUGGESTION_INTERVAL_MS=30000

# ----------------------------------------------------------------------------
# Phase 6 Step 2 — provider selection + credentials
# ----------------------------------------------------------------------------
# Provider env vars are OPT-IN. Each defaults to 'mock' when unset/empty so
# dev and tests stay deterministic and pay nothing. Setting a real provider
# is fail-fast: if the required key/url is missing the resolver throws at
# resolve time instead of silently falling back to mock (silent fallback
# would mask a misconfigured prod boot).
#
# Real provider clients live in server/src/adapters/{llm,embedding,stt}/.
# Default test runs MUST NOT exercise them — contract tests are gated by
# `E2E_ALLOW_REAL_PROVIDERS=1` so an accidental npm test never costs money.

STT_PROVIDER=mock
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# Real-provider contract test gate. Unset/0 means "skip everything that
# would call out to a paid provider"; the default test/CI configuration
# leaves this off.
# E2E_ALLOW_REAL_PROVIDERS=0

# Anthropic LLM — used when LLM_PROVIDER=anthropic.
#   ANTHROPIC_API_KEY        required
#   ANTHROPIC_MODEL          claude-sonnet-4-5 (override allowed)
#   ANTHROPIC_MAX_TOKENS     completion length cap
#   ANTHROPIC_TIMEOUT_MS     per-request HTTP timeout
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_MS=30000

# OpenAI embeddings — used when EMBEDDING_PROVIDER=openai. Dimensionality
# MUST stay at 1536 because the pgvector column is fixed-width. Other
# models that don't support `dimensions: 1536` are rejected at the boundary.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_TIMEOUT_MS=10000

# Naver Cloud CLOVA Speech Recognition — used when STT_PROVIDER=clova.
# The Step 2 client targets the REST short-recognition endpoint (no realtime
# gRPC streaming). The real adapter accepts Buffer audio only; passing a
# string fixture key throws SttUnsupportedInputError.
CLOVA_STT_URL=https://naveropenapi.apigw.ntruss.com/recog/v1/stt
CLOVA_CLIENT_ID=
CLOVA_CLIENT_SECRET=
CLOVA_STT_LANGUAGE=Kor
CLOVA_TIMEOUT_MS=10000
