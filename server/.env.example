# Server-side env. Copy to server/.env (gitignored).
# Use postgres-host-port from the project-root .env (default 5432).

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
STATIC_ORIGIN=http://localhost:8765

# DB — host-side connection (the migration tool runs from the host).
# Inside docker compose network, use postgres:5432 instead.
DATABASE_URL=postgres://kloser:kloser_dev@localhost:5432/kloser_dev

# Redis — same logic.
REDIS_URL=redis://localhost:6379
